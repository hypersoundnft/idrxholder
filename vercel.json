{
  "version": 2,
  "name": "idrxholder",
  "buildCommand": "cd client && npm install && npm run build",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
